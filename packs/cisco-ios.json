        },
        {
          "key": "match",
          "fieldId": "MATCH",
          "type": "dropdown",
          "label": "match",
          "default": "all",
          "options": [
            ["all", "all"],
            ["any", "any"]
          ],
          "description": "Match mode for wait_for conditions"
        },
        {
          "key": "retries",
          "fieldId": "RETRIES",
          "type": "number",
          "label": "retries",
          "default": 10,
          "min": 1,
          "max": 100,
          "description": "Number of retries for wait_for"
        },
        {
          "key": "interval",
          "fieldId": "INTERVAL",
          "type": "number",
          "label": "interval",
          "default": 1,
          "min": 1,
          "max": 60,
          "description": "Seconds between retries"
        }
