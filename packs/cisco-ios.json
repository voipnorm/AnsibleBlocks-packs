  "modules": [
    {
      "fqcn": "cisco.ios.ios_config",
      "blockType": "cisco_ios_config",
      "label": "ios_config",
      "tooltip": "Push configuration lines to a Cisco IOS device",
      "helpUrl": "https://docs.ansible.com/ansible/latest/collections/cisco/ios/ios_config_module.html",
      "supportsRawParams": true,
      "structure": { "type": "flat" },
      "fields": [
        {
          "key": "lines",
          "fieldId": "LINES",
          "type": "text",
          "label": "lines",
          "yamlType": "list",
          "default": "ip name-server 8.8.8.8",
          "description": "Configuration lines to push"
        },
        {
          "key": "parents",
          "fieldId": "PARENTS",
          "type": "text",
          "label": "parents",
          "yamlType": "list",
          "default": "",
          "description": "Parent configuration lines for context"
        },
        {
          "key": "before",
          "fieldId": "BEFORE",
          "type": "text",
          "label": "before",
          "yamlType": "list",
          "default": "",
          "description": "Lines to add before configuration changes"
        },
        {
          "key": "after",
          "fieldId": "AFTER",
          "type": "text",
          "label": "after",
          "yamlType": "list",
          "default": "",
          "description": "Lines to add after configuration changes"
        },
        {
          "key": "match",
          "fieldId": "MATCH",
          "type": "dropdown",
          "label": "match",
          "default": "line",
          "options": [
            ["line", "line"],
            ["strict", "strict"],
            ["exact", "exact"],
            ["none", "none"]
          ],
          "description": "Match algorithm for comparing running config"
        },
        {
          "key": "replace",
          "fieldId": "REPLACE",
          "type": "dropdown",
          "label": "replace",
          "default": "line",
          "options": [
            ["line", "line"],
            ["block", "block"]
          ],
          "description": "Replace strategy for config changes"
        },
        {
          "key": "save_when",
          "fieldId": "SAVE_WHEN",
          "type": "dropdown",
          "label": "save_when",
          "default": "never",
          "options": [
            ["never", "never"],
            ["always", "always"],
            ["modified", "modified"],
            ["changed", "changed"]
          ],
          "description": "When to save running config to startup"
        }
      ],
      "validationRules": {
        "requiredOneOf": ["lines", "src"]
      }
    },
    {
      "fqcn": "cisco.ios.ios_command",
      "blockType": "cisco_ios_command",
      "label": "ios_command",
      "tooltip": "Run show commands on a Cisco IOS device",
      "helpUrl": "https://docs.ansible.com/ansible/latest/collections/cisco/ios/ios_command_module.html",
      "structure": { "type": "flat" },
      "fields": [
        {
          "key": "commands",
          "fieldId": "COMMANDS",
